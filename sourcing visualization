
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);font-size:13px;color:var(--color-text-primary);padding:20px;line-height:1.5}
.tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:20px}
.tab-btn{padding:8px 16px;font-size:13px;font-weight:500;color:var(--color-text-secondary);background:var(--color-background-secondary);border:0.5px solid var(--color-border-secondary);border-radius:8px;cursor:pointer;transition:all .15s;white-space:nowrap}
.tab-btn:hover{background:var(--color-background-tertiary);color:var(--color-text-primary)}
.tab-btn.active{background:var(--color-text-primary);color:var(--color-background-primary);border-color:var(--color-text-primary)}
.legend{display:flex;gap:16px;flex-wrap:wrap;margin-bottom:20px;font-size:12px;color:var(--color-text-secondary)}
.legend-item{display:flex;align-items:center;gap:5px}
.legend-dot{width:10px;height:10px;border-radius:2px;flex-shrink:0}
.chart-grid{display:flex;flex-direction:column;gap:14px}
.country-row{display:flex;align-items:center;gap:12px}
.country-label{width:60px;font-size:12px;font-weight:500;color:var(--color-text-primary);flex-shrink:0;text-align:right}
.bar-wrap{flex:1;display:flex;height:32px;border-radius:6px;overflow:hidden;background:var(--color-background-secondary)}
.seg{height:100%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:500;transition:width .4s ease;overflow:hidden;white-space:nowrap}
.seg-label{padding:0 4px;pointer-events:none}
.total-label{width:50px;font-size:12px;color:var(--color-text-secondary);flex-shrink:0}
.section-label{font-size:11px;font-weight:500;letter-spacing:.07em;text-transform:uppercase;color:var(--color-text-secondary);margin-bottom:12px}
</style>

<div class="tabs" id="tabs"></div>
<div class="legend">
  <div class="legend-item"><div class="legend-dot" style="background:#71717a"></div>Contacted</div>
  <div class="legend-item"><div class="legend-dot" style="background:#f43f5e"></div>Converted</div>
  <div class="legend-item"><div class="legend-dot" style="background:#f59e0b"></div>Replied</div>
  <div class="legend-item"><div class="legend-dot" style="background:#a1a1aa"></div>Other</div>
</div>
<div class="section-label">Reply rates per country</div>
<div class="chart-grid" id="chart"></div>

<script>
const ROLES = [
  {key:'all', label:'All roles'},
  {key:'hcv', label:'Head of Computer Vision'},
  {key:'fe',  label:'Frontend engineer'},
  {key:'pd',  label:'Product designer'},
  {key:'as',  label:'Applied scientist'},
];

const DATA = {
  all: [
    {country:'France',  total:348,  contacted:64.7, converted:20.1, replied:13.8, other:1.4},
    {country:'Germany', total:403,  contacted:56.3, converted:24.8, replied:18.1, other:0.7},
    {country:'Spain',   total:180,  contacted:50.0, converted:29.4, replied:20.6, other:0},
    {country:'UK',      total:1044, contacted:71.6, converted:13.9, replied:13.4, other:1.1},
  ],
  hcv: [
    {country:'France',  total:67,  contacted:44.8, converted:31.3, replied:16.4, other:7.5},
    {country:'Germany', total:64,  contacted:50.0, converted:26.6, replied:18.8, other:4.7},
    {country:'Spain',   total:17,  contacted:47.1, converted:35.3, replied:17.6, other:0},
    {country:'UK',      total:305, contacted:73.8, converted:8.9,  replied:15.1, other:2.3},
  ],
  fe: [
    {country:'France',  total:38,  contacted:55.3, converted:26.3, replied:18.4, other:0},
    {country:'Germany', total:132, contacted:51.5, converted:28.8, replied:19.7, other:0},
    {country:'Spain',   total:65,  contacted:61.5, converted:21.5, replied:16.9, other:0},
    {country:'UK',      total:161, contacted:62.7, converted:20.5, replied:14.3, other:2.5},
  ],
  pd: [
    {country:'France',  total:13,  contacted:76.9, converted:23.1, replied:0, other:0},
    {country:'Germany', total:49,  contacted:30.6, converted:36.7, replied:0, other:32.7},
    {country:'Spain',   total:52,  contacted:40.4, converted:26.9, replied:0, other:32.7},
    {country:'UK',      total:117, contacted:67.5, converted:21.4, replied:0, other:11.1},
  ],
  as: [
    {country:'France',  total:230, contacted:71.3, converted:17.0, replied:11.7, other:0},
    {country:'Germany', total:158, contacted:70.9, converted:18.4, replied:10.8, other:0},
    {country:'Spain',   total:46,  contacted:45.7, converted:34.8, replied:19.6, other:0},
    {country:'UK',      total:461, contacted:74.4, converted:15.6, replied:10.0, other:0},
  ],
};

const COLORS = {
  contacted:'#71717a',
  converted:'#f43f5e',
  replied:'#f59e0b',
  other:'#a1a1aa',
};

let active = 'all';

function render(key) {
  active = key;
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.toggle('active', b.dataset.key === key));
  const rows = DATA[key];
  const chart = document.getElementById('chart');
  chart.innerHTML = rows.map(r => {
    const segs = ['contacted','converted','replied','other']
      .map(s => {
        const pct = r[s];
        if (!pct) return '';
        const minW = pct < 8 ? 0 : 1;
        const label = pct >= 8 ? `<span class="seg-label">${pct}%</span>` : '';
        return `<div class="seg" style="width:${pct}%;background:${COLORS[s]};color:#fff;min-width:${minW}px">${label}</div>`;
      }).join('');
    return `<div class="country-row">
      <div class="country-label">${r.country}</div>
      <div class="bar-wrap">${segs}</div>
      <div class="total-label">${r.total.toLocaleString()}</div>
    </div>`;
  }).join('');
}

const tabsEl = document.getElementById('tabs');
ROLES.forEach(r => {
  const b = document.createElement('button');
  b.className = 'tab-btn';
  b.dataset.key = r.key;
  b.textContent = r.label;
  b.onclick = () => render(r.key);
  tabsEl.appendChild(b);
});

render('all');
</script>
